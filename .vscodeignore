.vscode/**
.vscode-test/**
src/**
# Webview stylesheets must ship — localResourceRoots is extensionUri/src/ui, so
# they load from source, not from dist/. Keep this a glob: the single styles.css
# was split into base/settings/picker/hljs/code-block/varset/form, and a named
# exception would have silently shipped a CSS-less extension.
!src/ui/*.css
test/**
dist/test/**
.gitignore
.yarnrc
vsc-extension-quickstart.md
**/tsconfig.json
**/eslint.config.mjs
**/*.map
**/*.ts
**/.vscode-test.*
